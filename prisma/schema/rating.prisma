model Rating {
    id Int @id @default(autoincrement())

    bookingId Int
    booking   Booking @relation(fields: [bookingId], references: [id])

    riderId Int
    rider   Rider @relation(fields: [riderId], references: [id])

    rating  Int
    comment String?

    createdAt DateTime @default(now())

    @@unique([bookingId, riderId])
}
