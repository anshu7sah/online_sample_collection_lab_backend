enum MoneyTransferStatus {
    PENDING
    APPROVED
    REJECTED
}

enum MoneyTransferType {
    COLLECTION // money rider collected from user
    SETTLEMENT // money rider sends to company
    ADJUSTMENT // manual correction
}

model MoneyTransfer {
    id Int @id @default(autoincrement())

    riderId Int
    rider   Rider @relation(fields: [riderId], references: [id])

    amount Decimal
    type   MoneyTransferType
    status MoneyTransferStatus @default(PENDING)

    requestDate  DateTime  @default(now())
    approvedDate DateTime?

    approvedById Int?
    approvedBy   User? @relation("ApprovedTransfers", fields: [approvedById], references: [id])

    notes String?

    createdAt DateTime @default(now())
    user      User?    @relation(fields: [userId], references: [id])
    userId    Int?
}
